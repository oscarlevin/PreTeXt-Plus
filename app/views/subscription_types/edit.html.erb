<% content_for :title, "Editing subscription type" %>

<div class="md:w-2/3 mx-auto p-4 w-full">
  <h1 class="font-bold text-4xl">Editing subscription type</h1>

  <div class="pb-4">
    <%= render "form", subscription_type: @subscription_type %>
    <%= link_to "Show this subscription type", @subscription_type, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= link_to "Back to subscription types", subscription_types_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
