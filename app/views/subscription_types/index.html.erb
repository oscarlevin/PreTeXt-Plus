<% content_for :title, "Subscription types" %>

<div class="w-full p-4">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Subscription types</h1>
    <%= link_to "New subscription type", new_subscription_type_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="subscription_types" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @subscription_types.any? %>
      <% @subscription_types.each do |subscription_type| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render subscription_type %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", subscription_type, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= link_to "Edit", edit_subscription_type_path(subscription_type), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= button_to "Destroy", subscription_type, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No subscription types found.</p>
    <% end %>
  </div>
</div>
