<% content_for :content do %>
    <div class="w-full mx-auto p-2 md:w-2/3">
    <h1 class="text-3xl my-3 inline-flex items-center gap-2">
        <span>
        Manage Subscription Plans
        </span>
        <% if @subscriptions.any? %>
        <%= link_to @current_user.payment_processor.billing_portal.url, class: "inline-flex select-none items-center gap-2 rounded-md cursor-pointer ml-1 px-4 py-2 my-1 text-sm bg-gray-50 text-gray-700 drop-shadow-md hover:bg-white" do %>
            Manage payment info
        <% end %>
        <% end %>
        <span class="relative">
            <label for="subscribe-toggle" class="inline-flex select-none items-center gap-2 rounded-md cursor-pointer ml-1 px-4 py-2 my-1 text-sm bg-gray-50 text-gray-700 drop-shadow-md hover:bg-white">
                New Subscription Plan&nbsp;&#9662;
            </label>
            <input type="checkbox" id="subscribe-toggle" class="navbarMenuToggle sr-only">
            <span class="navbarMenu absolute z-40 my-1 right-0 w-48 bg-white rounded-md shadow-lg border border-gray-200 md:left-auto md:right-0">
            <% link_to_data = @current_user.subscribed? ? { turbo_method: "get", turbo_confirm: "You are already subscribed to a plan. Do you want to purchase an additional plan?" } : nil %>
            <% SubscriptionType.where.not(stripe_price_id: nil).where.not(stripe_price_id: "").each do |type| %>
                <%= link_to checkout_subscription_type_path(type), 
                    class: "select-none flex gap-3 items-center w-full bg-white px-4 py-2 my-1 text-sm hover:font-semibold focus:relative",
                    data: link_to_data do %>
                    <span class="inline-block size-10">
                        <svg class="size-full" viewBox="0 0 24 24" stroke-width="1.5" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor"><path d="M22 9V7C22 5.89543 21.1046 5 20 5H4C2.89543 5 2 5.89543 2 7V17C2 18.1046 2.89543 19 4 19H12M22 9H6M22 9V11" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M18.9923 14.125L21.5477 14.774C21.8137 14.8416 22.0013 15.0833 21.9931 15.3576C21.8214 21.1159 18.5 22 18.5 22C18.5 22 15.1786 21.1159 15.0069 15.3576C14.9987 15.0833 15.1863 14.8416 15.4523 14.774L18.0077 14.125C18.3308 14.043 18.6692 14.043 18.9923 14.125Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                    </span>
                    <span>
                        <%= type.name %>:
                        <%= type.price %>/seat/<%= type.recurrence %> (pay by card)
                    </span>
                <% end %>
                <% if type.invoiceable.present? %>
                    <%= link_to invoice_request_path, class: "select-none flex gap-3 items-center w-full bg-white px-4 py-2 my-1 text-sm hover:font-semibold focus:relative" do %>
                        <span class="inline-block size-10">
                            <svg class="size-full" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor"><path d="M8 14L16 14" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 10L10 10" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 18L12 18" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10 3H6C4.89543 3 4 3.89543 4 5V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V5C20 3.89543 19.1046 3 18 3H14.5M10 3V1M10 3V5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        </span>
                        <span>
                            <%= type.name %>:
                            <%= type.price %>/seat/<%= type.recurrence %> (request invoice)
                        </span>
                    <% end %>
                <% end %>
            <% end %>
            </span>
        </span>
    </h1>
    <div>
        <%= yield %>
    </div>
  </div>
<% end %>
<%= render template: "layouts/application" %>
