<% content_for :title, "New Project" %>

<div class="w-full px-4 pt-24 pb-12 md:px-0">
  <div class="mx-auto max-w-lg">
    <% if @project.errors.any? %>
      <div class="mb-6 rounded-md bg-red-50 border border-red-200 p-4">
        <h2 class="font-semibold text-red-800 mb-2">Please fix the following errors:</h2>
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <h1 class="font-bold text-3xl mb-2">New Project</h1>
    <p class="text-gray-500 mb-8">Configure your project, then dive into the editor.</p>

    <%= form_with model: @project, class: "space-y-8" do |form| %>
      <%# ── Project name ─────────────────────────────────────────── %>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1" for="project_title">
          Project name
        </label>
        <%= form.text_field :title,
              placeholder: "New Project",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        <p class="mt-1 text-xs text-gray-400">You can rename it later from the editor.</p>
      </div>

      <%# ── Source format ────────────────────────────────────────── %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-3">Source format</p>
        <div class="grid grid-cols-2 gap-4">
          <% [["pretext", "PreTeXt", "Semantic markup language designed for academic writing."],
              ["latex", "LaTeX-style PreTeXt", "A subset of the classic typesetting language focused on semantic markup and accessible output."]]
             .each do |value, label, description| %>
            <label class="relative flex cursor-pointer flex-col rounded-xl border-2 p-4 bg-gray-50 text-gray-500 hover:border-indigo-400 has-[:checked]:border-indigo-600 has-[:checked]:bg-indigo-50 has-[:checked]:text-gray-900 transition-colors">
              <%= form.radio_button :source_format, value, class: "sr-only" %>
              <span class="flex items-center gap-2 mb-1">
                <span class="font-semibold text-sm"><%= label %></span>
                <span class="hidden has-sibling-checked:inline text-indigo-600 text-xs font-medium">✓ selected</span>
              </span>
              <span class="text-xs"><%= description %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# ── Document type (coming soon) ──────────────────────────── %>
      <%# TODO: Uncomment when document_type UI is implemented.
          Available values: article (0), book (1), slideshow (2).
          The `document_type` column is already in the schema.
          Add radio cards here following the same pattern as source_format above,
          then permit :document_type in project_params.

      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-3">Document type</p>
        <div class="grid grid-cols-3 gap-4">
          [["article", "Article", "A focused standalone document."],
           ["book",    "Book",    "Multi-chapter book with front/back matter."],
           ["slideshow", "Slideshow", "Presentation slides."]]
          ... (radio cards, same pattern as source_format above) ...
        </div>
      </div>
      %>

      <%# ── Submit ───────────────────────────────────────────────── %>
      <div class="flex items-center gap-4 pt-2">
        <%= form.submit "Create project",
              class: "rounded-md px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
        <%= link_to "Cancel", projects_path,
              class: "rounded-md px-5 py-2.5 bg-gray-100 hover:bg-gray-200 font-medium text-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
